OPENAI_API_KEY=sk-...            # the only key the live VoicePipeline (STT+LLM+TTS) needs
ELEVENLABS_API_KEY=...           # NOT used by server.py's VoicePipeline path — leave blank unless a connector needs it

# --- Whisperer layer toggles (optional; defaults shown) ---
# SUGGERITORE_MODE=off            # on = memory layer + compact re-grounding
# SUGGERITORE_WATCHDOG=on         # SPEC §4 drift guard: re-answer on contradiction (default on; set off to reproduce the published cost baseline)
# WHISPERER_API_CONNECTOR=api_shopdemo  # per-client agent-tool connector module

# --- Live demo recommended config: memory on, low-latency, responsive panel ---
# SUGGERITORE_MODE=on             # turn the memory layer on (off by default)
# SUGGERITORE_WATCHDOG=off        # off in the live demo: recall is unchanged, latency minimal
# SUGGERITORE_DISTILL_EVERY=2     # distill every 2 turns so the live ledger panel updates promptly (default 4)

# --- Realtime mode (opt-in): the demo talks to a realtime speech-to-speech model ---
# instead of the VoicePipeline (STT+LLM+TTS). Default off = VoicePipeline (unchanged).
# SUGGERITORE_REALTIME=on         # on = relay browser audio to a realtime provider
# REALTIME_PROVIDER=xai           # xai = Grok Voice (grok-voice-latest, OpenAI-Realtime-compatible, ~$0.05/min); openai = gpt-realtime-mini
# XAI_API_KEY=xai-...             # required when REALTIME_PROVIDER=xai (Grok Voice); OPENAI_API_KEY covers the openai provider
# REALTIME_COST_LOG=true          # log real per-response cost + cache-hit % ([REALTIME-COST])
