# copy to .env and fill in. .env is gitignored, never commit it.
OPENAI_API_KEY=sk-...
ELEVENLABS_API_KEY=...

# --- Whisperer layer toggles (optional; defaults shown) ---
# SUGGERITORE_MODE=off            # on = memory layer + compact re-grounding
# SUGGERITORE_WATCHDOG=on         # SPEC §4 drift guard: re-answer on contradiction (default on; set off to reproduce the published cost baseline)
# WHISPERER_API_CONNECTOR=api_shopdemo  # per-client agent-tool connector module
